---
interface Project {
  slug: string;
  title: string;
}

interface Props {
  currentSlug: string;
  projects: Project[];
}

const { currentSlug, projects } = Astro.props;
const otherProjects = projects.filter((p) => p.slug !== currentSlug);
---

<section aria-labelledby="more-studies-label" class="px-gutter w-full max-w-content mx-auto">
  <div class="grid grid-cols-1 md:grid-cols-[1fr_3fr] gap-x-5 md:gap-x-10 gap-y-10">
    <h2 id="more-studies-label" class="text-heading-lg font-medium">
      See more case studies
    </h2>
    <div class="flex flex-col gap-10">
      <a href="/" class="text-body-sm link-underline text-foreground">See all</a>
      {otherProjects.map((project) => (
        <a href={`/projects/${project.slug}`} class="text-body-sm text-muted hover:text-foreground">
          {project.title}
        </a>
      ))}
    </div>
  </div>
</section>
