---
const currentPath = Astro.url.pathname;
---

<header class="px-gutter py-20">
  <nav aria-label="Main navigation" class="flex items-center justify-between w-full max-w-content mx-auto">
    <a href="/" class="text-heading-lg font-medium text-foreground">mng</a>
    <div class="flex items-center gap-15">
      <a
        href="/"
        class="text-heading-lg font-medium text-foreground"
        aria-current={currentPath === "/" ? "page" : undefined}
      >
        work
      </a>
      <a
        href="/about"
        class="text-heading-lg font-medium text-foreground"
        aria-current={currentPath === "/about" ? "page" : undefined}
      >
        about
      </a>
    </div>
  </nav>
</header>
