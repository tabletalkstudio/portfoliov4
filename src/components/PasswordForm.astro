---
interface Props {
  redirectTo: string;
  hasError?: boolean;
}

const { redirectTo, hasError = false } = Astro.props;
---

<form method="POST" action="/api/auth" class="flex flex-col gap-2">
  <input type="hidden" name="redirect" value={redirectTo} />
  <div class="flex flex-wrap items-center gap-2">
    <label for="password" class="sr-only">Password</label>
    <input
      type="password"
      id="password"
      name="password"
      placeholder="Secret code word"
      required
      autocomplete="off"
      aria-describedby="password-help"
      autofocus
      class="bg-surface-alt border border-border rounded-md px-3 py-2 text-body-sm text-foreground placeholder:text-muted leading-[1.5] w-64 focus:outline-2 focus:outline-focus-ring focus:outline-offset-2"
    />
    <button
      type="submit"
      class="bg-button-bg text-button-fg text-body-sm font-medium px-4 py-2 rounded-md leading-[1.5] cursor-pointer hover:opacity-90 focus:outline-2 focus:outline-focus-ring focus:outline-offset-2"
    >
      Submit
    </button>
  </div>
  {hasError && (
    <p role="alert" class="text-body-sm text-red-600 leading-[1.5]">
      Incorrect password. Please try again.
    </p>
  )}
  <p id="password-help" class="text-body-sm text-muted leading-[1.5]">
    Password not working? Reach out for support<br />
    <a href="mailto:mariah@tabletalk.studio" class="text-link underline">mariah@tabletalk.studio</a>.
  </p>
</form>
