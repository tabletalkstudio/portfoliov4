---
import { Image } from "astro:assets";

interface Props {
  title: string;
  description: string;
  slug: string;
  image: ImageMetadata;
  imageAlt: string;
}

const { title, description, slug, image, imageAlt } = Astro.props;
---

<article class="grid grid-cols-1 md:grid-cols-[1fr_3fr] gap-x-5 md:gap-x-10 gap-y-10">
  <div class="flex flex-col gap-5 order-last md:order-first">
    <h3 class="text-heading-lg">{title}</h3>
    <p class="text-body-sm text-muted">{description}</p>
    <a href={`/projects/${slug}`} class="text-body-sm link-underline text-foreground">
      Read case study
    </a>
  </div>
  <a href={`/projects/${slug}`} tabindex="-1" class="project-image-link relative block order-first md:order-last">
    <Image
      src={image}
      alt={imageAlt}
      class="w-full h-auto"
      loading="lazy"
      widths={[640, 960, 1280]}
      sizes="(max-width: 768px) 100vw, 75vw"
    />
    <span class="view-cursor pointer-events-none absolute flex items-center justify-center rounded-full bg-foreground text-surface text-caption" aria-hidden="true">view</span>
  </a>
</article>

<style>
  .view-cursor {
    display: none;
  }

  @media (hover: hover) and (pointer: fine) {
    .project-image-link {
      cursor: none;
    }

    .view-cursor {
      display: flex;
      width: 100px;
      height: 70px;
      opacity: 0;
      transform: scale(0.4);
      transition: opacity 0.4s ease, transform 0.4s ease;
      will-change: transform, opacity, left, top;
    }

    .project-image-link:hover .view-cursor {
      opacity: 1;
      transform: scale(1);
    }

    .project-image-link:active .view-cursor {
      transform: scale(0.8);
    }
  }
</style>

<script>
  function initViewCursors() {
    if (!window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;

    document.querySelectorAll('.project-image-link').forEach((link) => {
      const cursor = link.querySelector('.view-cursor') as HTMLElement;
      if (!cursor || cursor.dataset.init) return;
      cursor.dataset.init = '1';

      let mouseX = 0;
      let mouseY = 0;
      let currentX = 0;
      let currentY = 0;
      let rafId: number | null = null;
      let isHovering = false;

      function lerp(a: number, b: number, t: number) {
        return a + (b - a) * t;
      }

      function update() {
        const rect = (link as HTMLElement).getBoundingClientRect();
        const targetX = mouseX - rect.left - 50;
        const targetY = mouseY - rect.top - 35;
        currentX = lerp(currentX, targetX, 0.12);
        currentY = lerp(currentY, targetY, 0.12);
        cursor.style.left = `${currentX}px`;
        cursor.style.top = `${currentY}px`;
        if (isHovering) rafId = requestAnimationFrame(update);
      }

      link.addEventListener('mouseenter', (e) => {
        isHovering = true;
        mouseX = (e as MouseEvent).clientX;
        mouseY = (e as MouseEvent).clientY;
        const rect = (link as HTMLElement).getBoundingClientRect();
        currentX = mouseX - rect.left - 50;
        currentY = mouseY - rect.top - 35;
        cursor.style.left = `${currentX}px`;
        cursor.style.top = `${currentY}px`;
        rafId = requestAnimationFrame(update);
      });

      link.addEventListener('mousemove', (e) => {
        mouseX = (e as MouseEvent).clientX;
        mouseY = (e as MouseEvent).clientY;
      });

      link.addEventListener('mouseleave', () => {
        isHovering = false;
        if (rafId) {
          cancelAnimationFrame(rafId);
          rafId = null;
        }
      });
    });
  }

  initViewCursors();
  document.addEventListener('astro:after-swap', initViewCursors);
</script>
