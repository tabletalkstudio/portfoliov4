---
import { Image } from "astro:assets";

interface Props {
  title: string;
  description: string;
  slug: string;
  image: ImageMetadata;
  imageAlt: string;
}

const { title, description, slug, image, imageAlt } = Astro.props;
---

<article class="grid grid-cols-1 md:grid-cols-[1fr_3fr] gap-x-5 md:gap-x-10 gap-y-10">
  <div class="flex flex-col gap-5">
    <h3 class="text-heading-lg">{title}</h3>
    <p class="text-body-sm text-muted">{description}</p>
    <a href={`/projects/${slug}`} class="text-body-sm link-underline text-foreground">
      Read case study
    </a>
  </div>
  <a href={`/projects/${slug}`} tabindex="-1">
    <Image
      src={image}
      alt={imageAlt}
      class="w-full h-auto"
      loading="lazy"
      widths={[640, 960, 1280]}
      sizes="(max-width: 768px) 100vw, 75vw"
    />
  </a>
</article>
