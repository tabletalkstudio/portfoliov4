---
interface Props {
  company: string;
  role: string;
  years: string;
}

const { company, role, years } = Astro.props;
---

{/* Mobile: company 30% + role 70% top row, years full width below */}
{/* Desktop: company in 1fr left column, role + years in 3fr right column */}
<div class="px-gutter w-full max-w-content mx-auto mb-[20px] md:mb-[30px] lg:mb-[40px]">
  <div class="grid grid-cols-[30%_1fr] md:grid-cols-[20%_60%] gap-x-5 md:gap-x-10 gap-y-5">
    <div class="flex flex-col gap-5">
      <p class="text-body-sm text-muted">company</p>
      <p class="text-heading-lg">{company}</p>
    </div>
    <div class="md:grid md:grid-cols-2 md:gap-4">
      <div class="flex flex-col gap-5">
        <p class="text-body-sm text-muted">role</p>
        <p class="text-heading-lg">{role}</p>
      </div>
      <div class="hidden md:flex md:flex-col md:gap-5">
        <p class="text-body-sm text-muted">years</p>
        <p class="text-heading-lg">{years}</p>
      </div>
    </div>
    <div class="col-span-full md:hidden flex flex-col gap-5">
      <p class="text-body-sm text-muted">years</p>
      <p class="text-heading-lg">{years}</p>
    </div>
  </div>
</div>
