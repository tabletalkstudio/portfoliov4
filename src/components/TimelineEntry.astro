---
interface Props {
  company: string;
  roles: { title: string; dates: string }[];
}

const { company, roles } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-[1fr_3fr] gap-x-5 md:gap-x-10 gap-y-1">
  <p class="text-heading-lg font-medium">{company}</p>
  <div class="flex flex-col gap-1">
    {roles.map((role) => (
      <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline gap-x-4">
        <p class="text-body-sm text-muted">{role.title}</p>
        <p class="text-body-sm text-muted">{role.dates}</p>
      </div>
    ))}
  </div>
</div>
