---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionRow from "../components/SectionRow.astro";
import PasswordForm from "../components/PasswordForm.astro";

export const prerender = false;

const redirectTo = Astro.url.searchParams.get("redirect") || "/";
const hasError = Astro.url.searchParams.get("error") === "1";
---

<BaseLayout title="Password — Mariah Gardziola" hideFooter={true}>
  <div class="flex flex-col gap-section pt-page">
    <SectionRow label="Password" id="password">
      <PasswordForm redirectTo={redirectTo} hasError={hasError} />
    </SectionRow>
  </div>
</BaseLayout>
