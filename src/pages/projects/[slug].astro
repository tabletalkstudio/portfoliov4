---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectMeta from "../../components/ProjectMeta.astro";
import ProjectHero from "../../components/ProjectHero.astro";
import CaseStudyNav from "../../components/CaseStudyNav.astro";
import { getCollection, render } from "astro:content";

export const prerender = false;

const { slug } = Astro.params;

const allProjects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order
);

const project = allProjects.find((p) => p.data.slug === slug);

if (!project) {
  return Astro.redirect("/404");
}

const { Content } = await render(project);
---

<BaseLayout title={`${project.data.title} — Mariah Gardziola`} description={project.data.description}>
  <div class="flex flex-col gap-10 pt-page">
    <ProjectMeta
      company={project.data.company}
      role={project.data.role}
      years={project.data.years}
    />

    <ProjectHero
      title={project.data.title}
      description={project.data.description}
      credits={project.data.credits}
      heroImage={project.data.heroImage}
      heroImageAlt={project.data.heroImageAlt}
    />

    <article class="px-gutter w-full max-w-content mx-auto prose prose-neutral">
      <div class="grid grid-cols-1 md:grid-cols-[1fr_3fr] gap-x-5 md:gap-x-10">
        <div></div>
        <div class="text-body-sm text-muted [&_h2]:text-heading-lg [&_h2]:text-foreground [&_h2]:mt-5 [&_h2]:mb-5 [&_p]:mb-5 [&_img]:my-10 [&_a]:text-link [&_a]:underline [&_a]:[text-decoration-thickness:1.5px] [&_a]:[text-underline-offset:2px] [&_strong]:font-medium [&_strong]:text-foreground">
          <Content />
        </div>
      </div>
    </article>

    <CaseStudyNav
      currentSlug={project.data.slug}
      projects={allProjects.map((p) => ({ slug: p.data.slug, title: p.data.title, heroImage: p.data.heroImage, heroImageAlt: p.data.heroImageAlt }))}
    />
  </div>
</BaseLayout>
